<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{title}}</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <link rel="stylesheet" href="/css/dashboard.css"/>
  <link rel="stylesheet" href="/css/users.css"/>
</head>
<body class="bg-app">
  <div class="dashboard-container">
    <!-- HEADER SUPERIOR -->
    <header class="navbar-superior">
      <div class="navbar-superior-left">
        <img src="/media/logo.jpg" alt="CMD Cervantes" class="logo" />
        <div>
          <div class="navbar-brand">Sistema de Gestión de Inventario</div>
          <small class="text-muted">CMD Cervantes</small>
        </div>
      </div>

      <div class="navbar-superior-right">
        <div class="usuario">
          <img src="/media/iconoperfil.jpg" alt="{{nombreUsuario}}">
        <div>
        <div class="usuario-nombre">{{nombreUsuario}}</div>
          <small class="text-muted">{{rolTexto rolUsuario}}</small>
        </div>
      </div>

        
      </div>
    </header>

    <!-- NAVBAR SECUNDARIO -->
    <nav class="navbar-inferior">
  <div class="navbar-inferior-left">

    <a href="/dashboard" class="btn-inicio"><i class="bi bi-house-door"></i>Inicio</a>

    {{!-- Módulos solo para Admin --}}
    {{#if (eq rolUsuario "Admin")}}
      <a href="/usuarios" class="nav-link"><i class="bi bi-people"></i>Manejo de usuarios</a>
      <a href="/tuberia" class="nav-link"><i class="bi bi-diagram-3"></i>Manejo de Tubería</a>
      <a href="/reportes" class="nav-link"><i class="bi bi-file-earmark-text"></i>Generar Reportes</a>
      <a href="/sistema" class="nav-link"><i class="bi bi-gear"></i>Sistema</a>
    {{/if}}

    {{!-- Visible para todos --}}
    <a href="/inventario" class="nav-link"><i class="bi bi-box"></i>Inventario</a>

  </div>

  <div class="navbar-inferior-right">
    <form action="/logout" method="post">
      <button class="btn-cerrar"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</button>
    </form>
  </div>
</nav>


    <!-- CONTENIDO -->
    <main class="page-main">
      {{{body}}}
    </main>

    <!-- FOOTER -->
    <footer class="dashboard-footer text-center">
      Desarrollado por CMD Cervantes - 2025
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
