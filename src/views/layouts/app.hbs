<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{title}}</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <link rel="stylesheet" href="/css/dashboard.css"/>
  <link rel="stylesheet" href="/css/users.css"/>
</head>
<body class="bg-app">
  <div class="dashboard-container">
    <!-- HEADER SUPERIOR -->
    <header class="navbar-superior">
      <div class="navbar-superior-left">
        <img src="/media/logo.jpg" alt="CMD Cervantes" class="logo" />
        <div>
          <div class="navbar-brand">Sistema de Gestión de Inventario</div>
          <small class="text-muted">CMD Cervantes</small>
        </div>
      </div>

      <div class="navbar-superior-right">
        <div class="usuario">
          <img src="/media/iconoperfil.jpg" alt="{{nombreUsuario}}">
        <div>
        <div class="usuario-nombre">{{nombreUsuario}}</div>
          <small class="text-muted">{{rolTexto rolUsuario}}</small>
        </div>
      </div>

        
      </div>
    </header>

    <!-- NAVBAR SECUNDARIO -->
    <nav class="navbar-inferior">
  <div class="navbar-inferior-left">

    <a href="/dashboard" class="btn-inicio"><i class="bi bi-house-door"></i>Inicio</a>

    {{!-- Módulos solo para Admin --}}
    {{#if (eq rolUsuario "Admin")}}
      <a href="/usuarios" class="nav-link"><i class="bi bi-people"></i>Usuarios</a>
      <a href="/tuberia" class="nav-link"><i class="bi bi-diagram-3"></i>Tubería PVC</a>
      <a href="/reportes" class="nav-link"><i class="bi bi-file-earmark-text"></i>Reportes</a>
      <a href="/bitacora" class="nav-link"><i class="bi bi-gear"></i>Sistema</a>
    {{/if}}

    {{!-- Visible para todos --}}
    <div class="submenu-wrapper">
  
  <!-- Botón Inventario -->
  <button class="inventario-toggle {{#if inventarioActivo}}active{{/if}}"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#submenuInventario">
      <i class="bi bi-box-seam-fill me-2"></i> Inventario
      <i class="bi bi-caret-down-fill ms-2"></i>
  </button>

  <!-- Submenú -->
  <div id="submenuInventario" class="collapse {{#if inventarioActivo}}show{{/if}}">
    
    <a href="/inventario/accesorios" 
       class="nav-sublink {{#if (eq moduloActivo 'Accesorios')}}activo-sub{{/if}}">
        <i class="bi bi-wrench-adjustable me-2"></i> Accesorios
    </a>

    <a href="/inventario/cloro" 
       class="nav-sublink {{#if (eq moduloActivo 'Cloro')}}activo-sub{{/if}}">
        <i class="bi bi-bucket me-2"></i> Cloro
    </a>

    <a href="/inventario/herramientas" 
       class="nav-sublink {{#if (eq moduloActivo 'Herramientas')}}activo-sub{{/if}}">
        <i class="bi bi-hammer me-2"></i> Herramientas
    </a>

    <a href="/inventario/limpieza" 
       class="nav-sublink {{#if (eq moduloActivo 'Limpieza')}}activo-sub{{/if}}">
        <i class="bi bi-droplet me-2"></i> Limpieza
    </a>

    <a href="/inventario/medidores" 
       class="nav-sublink {{#if (eq moduloActivo 'Medidores')}}activo-sub{{/if}}">
        <i class="bi bi-speedometer2 me-2"></i> Medidores
    </a>

    <a href="/inventario/pegamentos" 
       class="nav-sublink {{#if (eq moduloActivo 'Pegamentos')}}activo-sub{{/if}}">
        <i class="bi bi-stickies me-2"></i> Pegamentos
    </a>

    <a href="/inventario/tuberia" 
       class="nav-sublink {{#if (eq moduloActivo 'Tubería')}}activo-sub{{/if}}">
        <i class="bi bi-diagram-3 me-2"></i> Tubería PVC
    </a>

  </div>
</div>

</div>

  <div class="navbar-inferior-right">
    <form action="/logout" method="post">
      <button class="btn-cerrar"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</button>
    </form>
  </div>
</nav>

    <!-- CONTENIDO -->
    <main class="page-main">
      {{#if mensaje}}
        <div class="alert alert-{{mensaje.tipo}} alert-dismissible fade show mb-3" role="alert">
          <strong>{{mensaje.texto}}</strong>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {{/if}}

      {{{body}}}
    </main>

    <!-- FOOTER -->
    <footer class="dashboard-footer text-center">
      Desarrollado por CMD Cervantes - 2025
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
