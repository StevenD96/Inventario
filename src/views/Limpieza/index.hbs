<section class="container-fluid users-wrapper">

  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-title">Limpieza</h1>

    <button
      type="button"
      class="btn btn-success btn-lg rounded-pill px-4"
      data-bs-toggle="modal"
      data-bs-target="#modalLimpieza">
      <i class="bi bi-plus-lg me-2"></i>Nuevo producto
    </button>
  </div>

  {{!-- Mensajes --}}
  {{#if add}}
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle-fill me-2"></i>
      Producto agregado correctamente.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {{/if}}

  {{#if edit}}
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle-fill me-2"></i>
      Producto actualizado correctamente.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {{/if}}

  {{#if delete}}
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle-fill me-2"></i>
      Producto eliminado correctamente.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {{/if}}

  {{#if error}}
    <div class="alert alert-danger alert-dismissible fade show">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      Ocurrió un error procesando la acción.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {{/if}}

  {{!-- Buscador --}}
  <form class="mb-3" method="get" action="/limpieza">
    <div class="searchbar">
      <i class="bi bi-search"></i>
      <input
        type="text"
        name="q"
        value="{{q}}"
        placeholder="Buscar por descripción..."
      />
    </div>
  </form>

  {{!-- Tabla --}}
  <div class="table-responsive users-card">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Descripción</th>
          <th>Cantidad</th>
          <th class="text-end">Acciones</th>
        </tr>
      </thead>

      <tbody>
        {{#if limpieza.length}}
          {{#each limpieza}}
            <tr>
              <td>{{descripcion}}</td>
              <td>{{cantidad}}</td>

              <td class="text-end pe-3">
                <a
                  href="#"
                  class="icon-btn btn-editar-limpieza"
                  data-id="{{id_limpieza}}"
                  data-descripcion="{{descripcion}}"
                  data-cantidad="{{cantidad}}">
                  <i class="bi bi-pencil-square"></i>
                </a>

                <a
                  href="#"
                  class="icon-btn danger btn-eliminar-limpieza"
                  data-id="{{id_limpieza}}">
                  <i class="bi bi-trash"></i>
                </a>
              </td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="3" class="text-center text-muted py-4">
              No hay productos de limpieza registrados.
            </td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>

  {{!-- Paginación --}}
  <div class="d-flex align-items-center justify-content-between mt-3">
    <div class="text-muted">
      Mostrando {{mostrando}} de {{total}} registros
    </div>

    {{#if (gt totalPages 1)}}
      <nav>
        <ul class="pagination mb-0">
          <li class="page-item {{#if (eq page 1)}}disabled{{/if}}">
            <a class="page-link" href="/limpieza?page={{prevPage}}&q={{q}}">Anterior</a>
          </li>

          {{#each pages}}
            <li class="page-item {{#if active}}active{{/if}}">
              <a class="page-link" href="/limpieza?page={{num}}&q={{../q}}">{{num}}</a>
            </li>
          {{/each}}

          <li class="page-item {{#if (eq page totalPages)}}disabled{{/if}}">
            <a class="page-link" href="/limpieza?page={{nextPage}}&q={{q}}">Siguiente</a>
          </li>
        </ul>
      </nav>
    {{/if}}
  </div>

</section>

{{> limpiezaModal }}
{{> limpiezaModalEditar }}
{{> limpiezaModalEliminar }}

<script>
document.addEventListener("DOMContentLoaded", () => {

  document.querySelectorAll(".btn-editar-limpieza").forEach(btn => {
    btn.addEventListener("click", e => {
      e.preventDefault();
      document.getElementById("edit_id_limpieza").value = btn.dataset.id;
      document.getElementById("edit_descripcion_limp").value = btn.dataset.descripcion;
      document.getElementById("edit_cantidad_limp").value = btn.dataset.cantidad;
      new bootstrap.Modal(document.getElementById("modalEditarLimpieza")).show();
    });
  });

  document.querySelectorAll(".btn-eliminar-limpieza").forEach(btn => {
    btn.addEventListener("click", e => {
      e.preventDefault();
      document.getElementById("delete_id_limpieza").value = btn.dataset.id;
      new bootstrap.Modal(document.getElementById("modalEliminarLimpieza")).show();
    });
  });

});
</script>
