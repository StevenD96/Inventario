<section class="container-fluid users-wrapper">

  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-title">Bitácora</h1>

    {{!-- Botones de exportación --}}
    <div class="d-flex gap-2">
      <button class="btn btn-success btn-lg rounded-pill px-4">
        <i class="bi bi-file-earmark-excel me-2"></i>Exportar Excel
      </button>

      <button class="btn btn-danger btn-lg rounded-pill px-4">
        <i class="bi bi-file-earmark-pdf me-2"></i>Exportar PDF
      </button>
    </div>
  </div>

  {{!-- Filtros --}}
  <form class="users-card p-3 mb-4" method="get" action="/bitacora">
    <h5 class="mb-3"><i class="bi bi-search me-2"></i>Filtros</h5>

    <div class="row g-3">

      <div class="col-md-3">
        <label class="form-label fw-semibold"><i class="bi bi-calendar3 me-2"></i>Mes</label>
        <select name="mes" class="form-select">
          {{{opcionesMes mes}}}
        </select>
      </div>

      <div class="col-md-3">
        <label class="form-label fw-semibold"><i class="bi bi-calendar-event me-2"></i>Año</label>
        <select name="anio" class="form-select">
          {{{opcionesAnio anio}}}
        </select>
      </div>

      <div class="col-md-3">
        <label class="form-label fw-semibold"><i class="bi bi-person me-2"></i>Usuario</label>
        <select name="usuario" class="form-select">
          <option value="Todos">Todos</option>
          {{#each usuarios}}
            <option value="{{this.nombre_usuario}}">{{this.nombre_usuario}}</option>
          {{/each}}
        </select>
      </div>

      <div class="col-md-3">
        <label class="form-label fw-semibold"><i class="bi bi-grid me-2"></i>Módulo</label>
        <select name="modulo" class="form-select">
          <option value="Todos">Todos</option>
          <option value="Login">Login</option>
          <option value="Usuarios">Usuarios</option>
          <option value="Tubería">Tubería</option>
          <option value="Inventario">Inventario</option>
        </select>
      </div>
    </div>

    <div class="mt-4 text-end">
      <button class="btn btn-success btn-lg rounded-pill px-4">
        <i class="bi bi-search me-2"></i>Buscar
      </button>
    </div>

  </form>

  {{!-- Tabla --}}
  <div class="table-responsive users-card">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Fecha y Hora</th>
          <th>Usuario</th>
          <th>Módulo</th>
          <th>Acción</th>
          <th>Descripción</th>
        </tr>
      </thead>

      <tbody>
        {{#if bitacora.length}}
          {{#each bitacora}}
            <tr>
              <td>{{this.fecha_hora}}</td>
              <td>{{this.usuario}}</td>
              <td>{{this.modulo}}</td>

              <td>
                {{#if (eq this.accion "CREAR")}}
                  <span class="chip chip-user">Crear</span>
                {{else if (eq this.accion "MODIFICAR")}}
                  <span class="chip chip-admin">Modificar</span>
                {{else}}
                  <span class="chip chip-user">Eliminar</span>
                {{/if}}
              </td>

              <td>{{this.descripcion}}</td>
            </tr>
          {{/each}}

        {{else}}
          <tr>
            <td colspan="5" class="text-center text-muted py-4">
              No se encontraron registros en la bitácora.
            </td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>

  {{!-- Paginación --}}
  <div class="d-flex align-items-center justify-content-between mt-3">
    <div class="text-muted">
      Mostrando {{mostrando}} de {{total}} registros
    </div>

    {{#if (gt totalPages 1)}}
      <nav>
        <ul class="pagination mb-0">
          <li class="page-item {{#if (eq page 1)}}disabled{{/if}}">
            <a class="page-link" href="/bitacora?page={{prevPage}}">Anterior</a>
          </li>

          {{#each pages}}
            <li class="page-item {{#if active}}active{{/if}}">
              <a class="page-link" href="/bitacora?page={{num}}">{{num}}</a>
            </li>
          {{/each}}

          <li class="page-item {{#if (eq page totalPages)}}disabled{{/if}}">
            <a class="page-link" href="/bitacora?page={{nextPage}}">Siguiente</a>
          </li>
        </ul>
      </nav>
    {{/if}}
  </div>

</section>
