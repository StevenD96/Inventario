<section class="container-fluid users-wrapper">

  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-title">Usuarios Inactivos</h1>

    <a href="/usuarios" class="btn btn-secondary btn-lg rounded-pill px-4">
      <i class="bi bi-arrow-left me-2"></i> Volver a Activos
    </a>
  </div>

  {{!-- Mensaje --}}
  {{#if reactivado}}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>
      Usuario reactivado correctamente.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {{/if}}

  {{#if error}}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      No se pudo reactivar el usuario.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  {{/if}}

  {{!-- Buscador --}}
  <form class="mb-3" method="get" action="/usuarios/inactivos">
    <div class="searchbar">
      <i class="bi bi-search"></i>
      <input type="text" name="q" value="{{q}}" placeholder="Buscar por nombre o correo...">
    </div>
  </form>

  {{!-- Tabla --}}
  <div class="table-responsive users-card">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Usuario</th>
          <th>Correo</th>
          <th>Rol</th>
          <th class="text-end">Acciones</th>
        </tr>
      </thead>

      <tbody>
        {{#each usuarios}}
          <tr>
            <td>{{nombre_completo}}</td>
            <td>{{nombre_usuario}}</td>
            <td>{{correo}}</td>
            <td class="text-center">
            {{#if (eq rol "Admin")}}
                <span class="chip chip-admin">{{rolTexto rol}}</span>
            {{else}}
                <span class="chip chip-user">{{rolTexto rol}}</span>
            {{/if}}
            </td>


            <td class="text-end pe-3">
              <form action="/usuarios/reactivar" method="POST" class="d-inline">
                <input type="hidden" name="id_usuario" value="{{id_usuario}}">
                <button class="icon-btn" title="Reactivar">
                  <i class="bi bi-arrow-clockwise text-success fs-5"></i>
                </button>
              </form>
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="6" class="text-center text-muted py-4">
              No hay usuarios inactivos.
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
