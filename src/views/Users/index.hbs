<section class="container-fluid users-wrapper">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-title">Usuarios</h1>

    <a href="/usuarios/nuevo" class="btn btn-success btn-lg rounded-pill px-4">
      <i class="bi bi-plus-lg me-2"></i>Nuevo usuario
    </a>
  </div>

  <form class="mb-3" method="get" action="/usuarios">
    <div class="searchbar">
      <i class="bi bi-search"></i>
      <input type="text" name="q" value="{{q}}" placeholder="Buscar por nombre o correo..." />
    </div>
  </form>

  <div class="table-responsive users-card">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Nombre completo</th>
          <th>Usuario</th>
          <th>Correo</th>
          <th class="text-center">Rol</th>
          <th class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        {{#if usuarios.length}}
          {{#each usuarios}}
            <tr>
              <td>{{this.nombre_completo}}</td>
              <td>{{this.nombre_usuario}}</td>
              <td>{{this.correo}}</td>
              <td class="text-center">
                {{#if (eq this.rol "Admin")}}
                  <span class="chip chip-admin">Admin</span>
                {{else}}
                  <span class="chip chip-user">User</span>
                {{/if}}
              </td>
              <td class="text-end pe-3">
                <a class="icon-btn" href="/usuarios/{{this.id_usuario}}/editar" title="Editar">
                  <i class="bi bi-pencil-square"></i>
                </a>
                <a class="icon-btn danger" href="/usuarios/{{this.id_usuario}}/eliminar" title="Eliminar">
                  <i class="bi bi-trash"></i>
                </a>
              </td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="5" class="text-center text-muted py-4">No hay usuarios para mostrar.</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>

  <div class="d-flex align-items-center justify-content-between mt-3">
    <div class="text-muted">
      Mostrando {{mostrando}} de {{total}} usuarios
    </div>

    {{#if (gt totalPages 1)}}
      <nav>
        <ul class="pagination mb-0">
          <li class="page-item {{#if (eq page 1)}}disabled{{/if}}">
            <a class="page-link" href="/usuarios?page={{prevPage}}&q={{q}}">Anterior</a>
          </li>

          {{#each pages}}
            <li class="page-item {{#if active}}active{{/if}}">
              <a class="page-link" href="/usuarios?page={{num}}&q={{../q}}">{{num}}</a>
            </li>
          {{/each}}

          <li class="page-item {{#if (eq page totalPages)}}disabled{{/if}}">
            <a class="page-link" href="/usuarios?page={{nextPage}}&q={{q}}">Siguiente</a>
          </li>
        </ul>
      </nav>
    {{/if}}
  </div>
</section>
