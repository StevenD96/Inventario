<div class="container d-flex justify-content-center align-items-center vh-100">
  <div class="card shadow-lg p-4 border-0 change-pass-card">
    <div class="text-center mb-3">
      <img src="/media/logo.jpg" alt="CMD Cervantes" class="mb-2" style="height:70px">
      <h4 class="fw-bold mt-3">Nueva Contraseña</h4>
      <p class="text-muted mb-4">Ingresa tu nueva contraseña de acceso</p>
    </div>

    <form action="/cambiar-clave" method="POST" id="formChangePassword">

      <!-- Nueva contraseña -->
      <div class="mb-3 position-relative">
        <label class="form-label fw-semibold">Nueva contraseña</label>
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-lock"></i></span>
          <input type="password" id="nueva_contrasena" name="nueva_contrasena" class="form-control border-start-0" placeholder="Ingresa tu nueva contraseña" required>
        </div>

        <!-- Requisitos -->
        <ul class="mt-2 list-unstyled small" id="requisitos">
          <li id="req-length"><i class="bi bi-x-circle text-danger"></i> Mínimo 8 caracteres</li>
          <li id="req-uppercase"><i class="bi bi-x-circle text-danger"></i> Al menos una mayúscula</li>
          <li id="req-number"><i class="bi bi-x-circle text-danger"></i> Al menos un número</li>
          <li id="req-special"><i class="bi bi-x-circle text-danger"></i> Al menos un carácter especial (!@#$%^&*)</li>
        </ul>
      </div>

      <!-- Confirmar contraseña -->
      <div class="mb-4 position-relative">
        <label class="form-label fw-semibold">Confirmar contraseña</label>
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-lock"></i></span>
          <input type="password" id="confirmar_contrasena" name="confirmar_contrasena" class="form-control border-start-0" placeholder="Confirma tu nueva contraseña" required>
        </div>
      </div>

      <!-- Botones -->
      <div class="d-grid gap-2">
        <button type="submit" class="btn btn-success fw-semibold">Guardar Nueva Contraseña</button>
        <a href="/" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script src="/js/changePassword.js"></script>
