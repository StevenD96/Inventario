<div class="d-flex justify-content-center align-items-center min-vh-100">
  <div class="card p-4 shadow rounded-4" style="max-width:400px; width:100%;">
    <div class="text-center mb-3">
      <img src="/media/logo.jpg" alt="CMD Cervantes" style="max-width:160px;">
    </div>

    <h4 class="text-center fw-bold mb-3">Bienvenido(a)</h4>

    <form action="/login" method="POST">
      <div class="mb-3">
        <label class="form-label">Nombre de usuario</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-person"></i></span>
          <input type="text" name="usuario" class="form-control" placeholder="Ingresa tu usuario" required>
        </div>
      </div>

      <div class="mb-2">
        <label class="form-label">Contraseña</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-lock"></i></span>
          <input type="password" name="contrasena" class="form-control" placeholder="Ingresa tu contraseña" required>
        </div>
      </div>

      <div class="text-end mb-3">
        <a href="/recuperar" class="text-success fw-semibold">Recuperar contraseña</a>

      </div>

      <button type="submit" class="btn btn-success w-100 rounded-pill">Iniciar Sesión</button>
    </form>

    {{#if error}}
      <div class="alert alert-danger mt-3 text-center">{{error}}</div>
    {{/if}}

    <p class="text-center text-muted small mt-3 mb-0">Desarrollado por CMD Cervantes - 2025</p>
  </div>
</div>
