<section class="container-fluid users-wrapper">

  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-title">Tubería PVC</h1>

    <button class="btn btn-success btn-lg rounded-pill px-4"
        data-bs-toggle="modal"
        data-bs-target="#modalTuberia">
      <i class="bi bi-plus-lg me-2"></i>Nuevo material
    </button>
  </div>


 {{!-- Material agregado --}}
{{#if add}}
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i>
    Material agregado correctamente.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{{/if}}

{{!-- Material duplicado --}}
{{#if existe}}
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    Ya existe un material con esa descripción, diámetro y especificación.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{{/if}}

{{!-- Material eliminado --}}
{{#if delete}}
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i>
    Material eliminado con éxito.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{{/if}}

{{!-- Material editado --}}
{{#if edit}}
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i>
    Material actualizado correctamente.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{{/if}}

{{!-- Error general --}}
{{#if error}}
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    Ocurrió un error procesando la acción.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{{/if}}



  {{!-- Buscador --}}
  <form class="mb-3" method="get" action="/tuberia">
    <div class="searchbar">
      <i class="bi bi-search"></i>
      <input 
        type="text" 
        name="q" 
        value="{{q}}" 
        placeholder="Buscar por descripción o diámetro..."
      />
    </div>
  </form>

  {{!-- Tabla --}}
  <div class="table-responsive users-card">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Descripción</th>
          <th>Diámetro</th>
          <th>Especificación</th>
          <th>Cantidad</th>
          <th class="text-end">Acciones</th>
        </tr>
      </thead>

      <tbody>
        {{#if tuberias.length}}
          {{#each tuberias}}
            <tr>
              <td>{{descripcion}}</td>
              <td>{{diametro}}</td>
              <td>{{especificacion}}</td>
              <td>{{cantidad}}</td>

              <td class="text-end pe-3">
              <a 
                class="icon-btn btn-editar-tuberia"
                href="#"
                data-id="{{id_tuberia}}"
                data-descripcion="{{descripcion}}"
                data-diametro="{{diametro}}"
                data-especificacion="{{especificacion}}"
                data-cantidad="{{cantidad}}"
              >
                <i class="bi bi-pencil-square"></i>
              </a>



                <a 
                  class="icon-btn danger btn-eliminar-tuberia"
                  data-id="{{id_tuberia}}"
                  href="#"
                  title="Eliminar"
                >
                  <i class="bi bi-trash"></i>
                </a>

              </td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="6" class="text-center text-muted py-4">
              No hay materiales para mostrar.
            </td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>

  <div class="d-flex align-items-center justify-content-between mt-3">
    <div class="text-muted">
      Mostrando {{mostrando}} de {{total}} materiales
    </div>

    {{#if (gt totalPages 1)}}
      <nav>
        <ul class="pagination mb-0">
          <li class="page-item {{#if (eq page 1)}}disabled{{/if}}">
            <a class="page-link" href="/tuberia?page={{prevPage}}&q={{q}}">Anterior</a>
          </li>

          {{#each pages}}
            <li class="page-item {{#if active}}active{{/if}}">
              <a class="page-link" href="/tuberia?page={{num}}&q={{../q}}">{{num}}</a>
            </li>
          {{/each}}

          <li class="page-item {{#if (eq page totalPages)}}disabled{{/if}}">
            <a class="page-link" href="/tuberia?page={{nextPage}}&q={{q}}">Siguiente</a>
          </li>
        </ul>
      </nav>
    {{/if}}
  </div>

</section>

{{> tuberiaModal }}
{{> tuberiaModalEditar }}
{{> tuberiaModalEliminar }}


<script>
document.addEventListener("DOMContentLoaded", () => {

  /* --- ELIMINAR MATERIAL --- */
  const botonesEliminar = document.querySelectorAll(".btn-eliminar-tuberia");

  botonesEliminar.forEach(btn => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();

      const id = btn.dataset.id;
      document.getElementById("delete_id_tuberia").value = id;

      const modal = new bootstrap.Modal(document.getElementById("modalTuberiaEliminar"));
      modal.show();
    });
  });

  /* --- EDITAR MATERIAL --- */
  const editarBtns = document.querySelectorAll(".btn-editar-tuberia");

  editarBtns.forEach(btn => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();

      const id = btn.dataset.id;

      document.getElementById("edit_id_tuberia").value = id;
      document.getElementById("edit_descripcion").value = btn.dataset.descripcion;
      document.getElementById("edit_diametro").value = btn.dataset.diametro;
      document.getElementById("edit_especificacion").value = btn.dataset.especificacion;
      document.getElementById("edit_cantidad").value = btn.dataset.cantidad;

      const form = document.getElementById("formEditarMaterial");
      form.action = `/tuberia/editar/${id}`;

      const modal = new bootstrap.Modal(document.getElementById("modalEditarTuberia"));
      modal.show();
    });
  });

});
</script>